# Copy to .env.development or .env.production and fill in.
# Project API key from PostHog → Settings → Project (snippet key, often phc_…).
# Never commit real keys; .env* is gitignored except this example file.

GATSBY_POSTHOG_KEY=
# Optional: EU cloud https://eu.posthog.com — omit for US cloud default.
# GATSBY_POSTHOG_HOST=https://app.posthog.com
